<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.StuStudentMapper">

    <resultMap type="StuStudent" id="StuStudentResult">
        <result property="studentId"     column="student_id"     />
        <result property="admissionYear" column="admission_year" />
        <result property="classNum"      column="class_num"      />
        <result property="studentNum"    column="student_num"    />
        <result property="account"       column="account"        />
        <result property="password"      column="password"       />
        <result property="studentName"   column="student_name"   />
        <result property="sex"           column="sex"            />
        <result property="status"        column="status"         />
        <result property="delFlag"       column="del_flag"       />
        <result property="loginIp"       column="login_ip"       />
        <result property="loginDate"     column="login_date"     />
        <result property="loginToken"    column="login_token"    />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>

    <sql id="selectStuStudentVo">
        select student_id, admission_year, class_num, student_num, account, password, student_name, sex, status, del_flag, login_ip, login_date, login_token, create_by, create_time, update_by, update_time, remark
        from stu_student
    </sql>

    <select id="selectStuStudentById" parameterType="Long" resultMap="StuStudentResult">
        <include refid="selectStuStudentVo"/>
        where student_id = #{studentId} and del_flag = '0'
    </select>

    <select id="selectStuStudentByAccount" parameterType="String" resultMap="StuStudentResult">
        <include refid="selectStuStudentVo"/>
        where account = #{account} and del_flag = '0'
    </select>

    <select id="selectStuStudentList" parameterType="StuStudent" resultMap="StuStudentResult">
        <include refid="selectStuStudentVo"/>
        where del_flag = '0'
        <if test="admissionYear != null">
            AND admission_year = #{admissionYear}
        </if>
        <if test="classNum != null">
            AND class_num = #{classNum}
        </if>
        <if test="studentNum != null">
            AND student_num = #{studentNum}
        </if>
        <if test="account != null and account != ''">
            AND account like concat('%', #{account}, '%')
        </if>
        <if test="studentName != null and studentName != ''">
            AND student_name like concat('%', #{studentName}, '%')
        </if>
        <if test="sex != null and sex != ''">
            AND sex = #{sex}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        order by admission_year desc, class_num asc, student_num asc
    </select>

    <select id="checkAccountUnique" parameterType="String" resultMap="StuStudentResult">
        <include refid="selectStuStudentVo"/>
        where account = #{account} and del_flag = '0' limit 1
    </select>

    <insert id="insertStuStudent" parameterType="StuStudent" useGeneratedKeys="true" keyProperty="studentId">
        insert into stu_student (
            admission_year,
            class_num,
            student_num,
            account,
            password,
            student_name,
            sex,
            status,
            del_flag,
            create_by,
            create_time,
            remark
        ) values (
            #{admissionYear},
            #{classNum},
            #{studentNum},
            #{account},
            #{password},
            #{studentName},
            #{sex},
            #{status},
            #{delFlag},
            #{createBy},
            sysdate(),
            #{remark}
        )
    </insert>

    <update id="updateStuStudent" parameterType="StuStudent">
        update stu_student
        <set>
            <if test="admissionYear != null">admission_year = #{admissionYear},</if>
            <if test="classNum != null">class_num = #{classNum},</if>
            <if test="studentNum != null">student_num = #{studentNum},</if>
            <if test="account != null and account != ''">account = #{account},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="studentName != null">student_name = #{studentName},</if>
            <if test="sex != null and sex != ''">sex = #{sex},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="loginIp != null and loginIp != ''">login_ip = #{loginIp},</if>
            <if test="loginDate != null">login_date = #{loginDate},</if>
            <if test="loginToken != null">login_token = #{loginToken},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where student_id = #{studentId}
    </update>

    <update id="deleteStuStudentById" parameterType="Long">
        update stu_student set del_flag = '2' where student_id = #{studentId}
    </update>

    <update id="deleteStuStudentByIds" parameterType="Long">
        update stu_student set del_flag = '2' where student_id in
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </update>

</mapper>
