<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.StuHomeworkMapper">

    <resultMap type="StuHomework" id="StuHomeworkResult">
        <result property="homeworkId"     column="homework_id"     />
        <result property="title"          column="title"           />
        <result property="content"        column="content"         />
        <result property="deadline"       column="deadline"        />
        <result property="admissionYear"  column="admission_year"  />
        <result property="classNum"       column="class_num"       />
        <result property="storagePath"    column="storage_path"    />
        <result property="maxFileSize"   column="max_file_size"   />
        <result property="status"         column="status"          />
        <result property="delFlag"        column="del_flag"        />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="submitCount"    column="submit_count"    />
        <result property="gradedCount"    column="graded_count"    />
    </resultMap>

    <sql id="selectStuHomeworkVo">
        select h.homework_id, h.title, h.content, h.deadline, h.admission_year, h.class_num,
               h.storage_path, h.max_file_size, h.status, h.del_flag,
               h.create_by, h.create_time, h.update_by, h.update_time, h.remark,
               (select count(*) from stu_homework_submit s where s.homework_id = h.homework_id) as submit_count,
               (select count(*) from stu_homework_submit s where s.homework_id = h.homework_id and s.status = '1') as graded_count
        from stu_homework h
    </sql>

    <select id="selectStuHomeworkById" parameterType="Long" resultMap="StuHomeworkResult">
        <include refid="selectStuHomeworkVo"/>
        where homework_id = #{homeworkId} and del_flag = '0'
    </select>

    <select id="selectStuHomeworkList" parameterType="StuHomework" resultMap="StuHomeworkResult">
        <include refid="selectStuHomeworkVo"/>
        where del_flag = '0'
        <if test="title != null and title != ''">
            AND title like concat('%', #{title}, '%')
        </if>
        <if test="admissionYear != null">
            AND admission_year = #{admissionYear}
        </if>
        <if test="classNum != null">
            AND class_num = #{classNum}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        order by create_time desc
    </select>

    <insert id="insertStuHomework" parameterType="StuHomework" useGeneratedKeys="true" keyProperty="homeworkId">
        insert into stu_homework (
            title,
            content,
            <if test="deadline != null">deadline,</if>
            admission_year,
            class_num,
            storage_path,
            max_file_size,
            status,
            del_flag,
            create_by,
            create_time,
            remark
        ) values (
            #{title},
            #{content},
            <if test="deadline != null">#{deadline},</if>
            #{admissionYear},
            #{classNum},
            #{storagePath},
            #{maxFileSize},
            #{status},
            '0',
            #{createBy},
            sysdate(),
            #{remark}
        )
    </insert>

    <update id="updateStuHomework" parameterType="StuHomework">
        update stu_homework
        <set>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="deadline != null">deadline = #{deadline},</if>
            <if test="admissionYear != null">admission_year = #{admissionYear},</if>
            <if test="classNum != null">class_num = #{classNum},</if>
            <if test="storagePath != null and storagePath != ''">storage_path = #{storagePath},</if>
            <if test="maxFileSize != null">max_file_size = #{maxFileSize},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where homework_id = #{homeworkId}
    </update>

    <update id="deleteStuHomeworkById" parameterType="Long">
        update stu_homework set del_flag = '2' where homework_id = #{homeworkId}
    </update>

    <update id="deleteStuHomeworkByIds">
        update stu_homework set del_flag = '2' where homework_id in
        <foreach item="homeworkId" collection="array" open="(" separator="," close=")">
            #{homeworkId}
        </foreach>
    </update>

</mapper>
